# Supabase project URL, e.g. https://your-project-ref.supabase.co
SUPABASE_URL=

# Server-side only. Store the real value in GitHub Actions Secrets, never in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection string for migrations or admin scripts.
SUPABASE_DB_URL=

# Comma-separated RSS feed URLs for the collector.
NEWS_RSS_URLS=

# Set to true for local testing without writing to Supabase.
COLLECTOR_DRY_RUN=false

# Server-side admin API key for Supabase Edge Functions. Store the real value as a Supabase secret.
ADMIN_API_KEY=

# Optional CORS origin for admin calls, e.g. https://yoddeu.github.io
ADMIN_ALLOWED_ORIGIN=
